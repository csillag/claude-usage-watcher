#!/usr/bin/env python3
"""claude-usage: print current Claude Max subscription usage as pretty JSON.

Reads OAuth credentials from ~/.claude/.credentials.json (the same file
Claude Code uses), refreshes the access token if expired, GETs
https://api.anthropic.com/api/oauth/usage, and prints the response body
with json.dumps(indent=2). All errors go to stderr; only JSON to stdout.
"""

import argparse
import json
import os
import stat
import sys
import tempfile
import time
import urllib.request
import urllib.error
from datetime import datetime, timezone
from pathlib import Path

DEFAULT_CREDENTIALS_PATH = Path.home() / ".claude" / ".credentials.json"
EXPIRY_SKEW_SECONDS = 60


class CredentialsError(Exception):
    """Raised when credentials cannot be loaded or parsed."""


def load_credentials(path=DEFAULT_CREDENTIALS_PATH):
    """Read the credentials file and return the claudeAiOauth dict.

    Raises CredentialsError on missing file, malformed JSON, or missing
    claudeAiOauth block.
    """
    path = Path(path)
    if not path.exists():
        raise CredentialsError(
            f"No credentials file at {path}. Run `claude` to authenticate first."
        )
    try:
        raw = json.loads(path.read_text())
    except json.JSONDecodeError as e:
        raise CredentialsError(f"Credentials file at {path} is malformed: {e}") from e
    oauth = raw.get("claudeAiOauth")
    if not isinstance(oauth, dict):
        raise CredentialsError(
            f"Credentials file at {path} has no claudeAiOauth block."
        )
    return oauth


def is_expired(creds, now=None):
    """Return True if the access token is expired or expiring soon.

    `expiresAt` in the credentials file is epoch milliseconds.
    A 60-second skew margin avoids racing the token boundary.
    """
    if now is None:
        now = time.time()
    expires_at_ms = creds.get("expiresAt")
    if expires_at_ms is None:
        return True
    return (expires_at_ms / 1000.0) - EXPIRY_SKEW_SECONDS <= now


USAGE_URL = "https://api.anthropic.com/api/oauth/usage"
PROFILE_URL = "https://api.anthropic.com/api/oauth/profile"
BETA_HEADER = "oauth-2025-04-20"


class AuthError(Exception):
    """Raised on 401 from the usage endpoint (caller may retry after refresh)."""


class UsageFetchError(Exception):
    """Raised on any other HTTP or network error from the usage endpoint."""


def fetch_usage(access_token):
    """GET the usage endpoint and return the parsed JSON body."""
    return _oauth_get(USAGE_URL, access_token)


def fetch_profile(access_token):
    """GET the profile endpoint and return the parsed JSON body.

    Same auth and beta header as fetch_usage. 401 -> AuthError; other
    HTTP/network errors -> UsageFetchError (the user-visible failure
    shape is identical to a usage fetch failure).
    """
    return _oauth_get(PROFILE_URL, access_token)


def _oauth_get(url, access_token):
    """GET `url` with OAuth bearer + beta header, return parsed JSON."""
    req = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Bearer {access_token}",
            "anthropic-beta": BETA_HEADER,
        },
        method="GET",
    )
    try:
        with urllib.request.urlopen(req) as resp:
            body = resp.read()
    except urllib.error.HTTPError as e:
        if e.code == 401:
            raise AuthError(f"401 Unauthorized: {e.read().decode('utf-8', 'replace')}") from e
        raise UsageFetchError(f"HTTP {e.code}: {e.reason}") from e
    except urllib.error.URLError as e:
        raise UsageFetchError(f"Network error: {e.reason}") from e
    return json.loads(body)


OAUTH_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"
REFRESH_URL = "https://platform.claude.com/v1/oauth/token"


class RefreshError(Exception):
    """Raised when the refresh-token exchange fails."""


def refresh(path=DEFAULT_CREDENTIALS_PATH):
    """Refresh the access token and atomically rewrite the credentials file.

    Returns the updated claudeAiOauth dict.
    """
    path = Path(path)
    raw = json.loads(path.read_text())
    creds = raw["claudeAiOauth"]
    refresh_token = creds["refreshToken"]

    body = json.dumps({
        "grant_type": "refresh_token",
        "refresh_token": refresh_token,
        "client_id": OAUTH_CLIENT_ID,
    }).encode("utf-8")
    req = urllib.request.Request(
        REFRESH_URL,
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req) as resp:
            payload = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        raise RefreshError(
            f"Refresh failed: HTTP {e.code} {e.reason}: "
            f"{e.read().decode('utf-8', 'replace')}"
        ) from e
    except urllib.error.URLError as e:
        raise RefreshError(f"Refresh failed: network: {e.reason}") from e

    creds["accessToken"] = payload["access_token"]
    creds["refreshToken"] = payload.get("refresh_token", refresh_token)
    if "expires_at" in payload:
        creds["expiresAt"] = int(payload["expires_at"])
    else:
        creds["expiresAt"] = int((time.time() + int(payload["expires_in"])) * 1000)
    raw["claudeAiOauth"] = creds

    _atomic_write(path, json.dumps(raw, indent=2))
    return creds


BAR_WIDTH = 20
BAR_FILL = "█"   # █
BAR_EMPTY = "░"  # ░
LABEL_WIDTH = 17
BAR_FIELD_WIDTH = BAR_WIDTH + 2  # 22, includes [ and ]


def _humanize_reset(resets_at, now):
    """Format the time until `resets_at` (ISO-8601 string) relative to `now`.

    Returns "no usage" if resets_at is None, "reset" if past, otherwise
    "resets in {N}m" / "resets in {H}h {M}m" / "resets in {D}d {H}h"
    using truncation.
    """
    if resets_at is None:
        return "no usage"
    s = resets_at
    # datetime.fromisoformat in 3.11+ accepts trailing Z, but be defensive.
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    reset_dt = datetime.fromisoformat(s)
    if reset_dt.tzinfo is None:
        reset_dt = reset_dt.replace(tzinfo=timezone.utc)
    if now.tzinfo is None:
        now = now.replace(tzinfo=timezone.utc)
    delta = reset_dt - now
    total_seconds = int(delta.total_seconds())
    if total_seconds <= 0:
        return "reset"
    minutes = total_seconds // 60
    if minutes < 60:
        return f"resets in {minutes}m"
    hours = minutes // 60
    if hours < 24:
        return f"resets in {hours}h {minutes % 60}m"
    days = hours // 24
    return f"resets in {days}d {hours % 24}h"


def _render_bar(utilization):
    """Render a 20-char bar of █/░ for a 0..100 utilization value."""
    filled = round((utilization / 100.0) * BAR_WIDTH)
    if filled < 0:
        filled = 0
    elif filled > BAR_WIDTH:
        filled = BAR_WIDTH
    return "[" + BAR_FILL * filled + BAR_EMPTY * (BAR_WIDTH - filled) + "]"


def _render_row(label, entry, now):
    """Render one row. `entry` is None or a dict with utilization+resets_at."""
    if entry is None:
        # Em-dash bar, blank pct, "no usage". Pad to align with present rows.
        # Present row tail after label: bar(22) + " " + pct(>3) + "%" + "   " + reset
        # = 22 + 1 + 3 + 1 + 3 = 30 chars before the status text.
        # For null: "—" left-aligned to 22 + 1 + 3 spaces (pct) + 1 (no %) + 3 sep
        em = "—"  # —
        return f"{label:<{LABEL_WIDTH}}{em:<{BAR_FIELD_WIDTH}}        no usage"
    util = entry.get("utilization") or 0
    bar = _render_bar(util)
    pct = round(util)
    reset = _humanize_reset(entry.get("resets_at"), now)
    return f"{label:<{LABEL_WIDTH}}{bar} {pct:>3}%   {reset}"


def _render_extra(extra):
    """Render the 'Extra credits' line."""
    label = "Extra credits"
    if not extra or not extra.get("is_enabled"):
        return f"{label:<{LABEL_WIDTH}}disabled"
    util = extra.get("utilization")
    monthly = extra.get("monthly_limit")
    currency = extra.get("currency") or "USD"
    if util is None or monthly is None:
        return f"{label:<{LABEL_WIDTH}}enabled"
    symbol = "$" if currency == "USD" else currency + " "
    return f"{label:<{LABEL_WIDTH}}{round(util)}% of {symbol}{monthly}"


_PLAN_TOKEN_MAP = {"claude": "Claude", "max": "Max", "pro": "Pro"}


def _format_plan_name(rate_limit_tier):
    """Derive a friendly plan name from a rate_limit_tier string.

    Strips a leading "default_", splits on "_", capitalizes the
    well-known tokens (claude/max/pro), and leaves everything else
    as-is so that "20x" stays "20x".
    """
    if rate_limit_tier.startswith("default_"):
        rate_limit_tier = rate_limit_tier[len("default_"):]
    tokens = rate_limit_tier.split("_")
    pretty = [_PLAN_TOKEN_MAP.get(t, t) for t in tokens]
    return " ".join(pretty)


def _format_plan_header(profile):
    """Build the one-line plan header from a profile response.

    Returns "Plan: unknown" if the expected keys are missing, so a
    surprise schema change degrades to a label rather than a crash.
    """
    try:
        org = profile["organization"]
        tier = org["rate_limit_tier"]
        status = org["subscription_status"]
        created_at = org["subscription_created_at"]
    except (KeyError, TypeError):
        return "Plan: unknown"
    plan = _format_plan_name(tier)
    iso = created_at[:-1] + "+00:00" if created_at.endswith("Z") else created_at
    try:
        date = datetime.fromisoformat(iso).date().isoformat()
    except ValueError:
        return "Plan: unknown"
    if status == "active":
        return f"Plan: {plan}  (active since {date})"
    return f"Plan: {plan}  (status: {status}, since {date})"


def format_human(data, profile=None, now=None):
    """Render usage `data` as a multi-line human-readable string.

    If `profile` is provided, prepend a plan-header line and a blank
    line. When `profile` is None, the output matches the pre-header
    behaviour exactly (callers that pass only `data` keep working).
    """
    if now is None:
        now = datetime.now(timezone.utc)
    lines = []
    if profile is not None:
        lines.append(_format_plan_header(profile))
        lines.append("")
    lines.extend([
        _render_row("5-hour session", data.get("five_hour"), now),
        _render_row("7-day weekly", data.get("seven_day"), now),
        _render_extra(data.get("extra_usage")),
    ])
    return "\n".join(lines)


EXIT_OK = 0
EXIT_NO_CREDS = 2
EXIT_REFRESH_FAILED = 3
EXIT_NETWORK = 4
EXIT_AUTH_AFTER_REFRESH = 5


def main(argv=None):
    """Load credentials, refresh if needed, fetch usage, print JSON to stdout.

    Returns exit code:
      0 - success
      2 - credentials missing or malformed
      3 - token refresh failed
      4 - network/HTTP error from usage endpoint
      5 - authentication failed even after refresh
    """
    parser = argparse.ArgumentParser(
        prog="claude-usage",
        description="Print Claude Max subscription usage as pretty JSON.",
    )
    parser.add_argument(
        "--credentials",
        default=str(DEFAULT_CREDENTIALS_PATH),
        help="Path to the Claude Code credentials JSON file.",
    )
    parser.add_argument(
        "--human",
        action="store_true",
        help="Render a human-readable text report instead of JSON.",
    )
    args = parser.parse_args(argv)
    creds_path = Path(args.credentials)

    try:
        creds = load_credentials(creds_path)
    except CredentialsError as e:
        print(str(e), file=sys.stderr)
        return EXIT_NO_CREDS

    if is_expired(creds):
        try:
            creds = refresh(creds_path)
        except RefreshError as e:
            print(f"Token refresh failed. Re-auth via `claude /login`.\n{e}",
                  file=sys.stderr)
            return EXIT_REFRESH_FAILED

    def _fetch_all(token):
        data = fetch_usage(token)
        profile = fetch_profile(token)
        return data, profile

    try:
        data, profile = _fetch_all(creds["accessToken"])
    except AuthError:
        try:
            creds = refresh(creds_path)
        except RefreshError as e:
            print(f"Token refresh failed. Re-auth via `claude /login`.\n{e}",
                  file=sys.stderr)
            return EXIT_REFRESH_FAILED
        try:
            data, profile = _fetch_all(creds["accessToken"])
        except AuthError as e:
            print(f"Authentication failed even after refresh. Re-auth.\n{e}",
                  file=sys.stderr)
            return EXIT_AUTH_AFTER_REFRESH
        except UsageFetchError as e:
            print(str(e), file=sys.stderr)
            return EXIT_NETWORK
    except UsageFetchError as e:
        print(str(e), file=sys.stderr)
        return EXIT_NETWORK

    if args.human:
        print(format_human(data, profile=profile))
    else:
        print(json.dumps({"profile": profile, "usage": data}, indent=2))
    return EXIT_OK


def _atomic_write(path, contents):
    """Write `contents` to `path` atomically, preserving permissions."""
    path = Path(path)
    try:
        existing_mode = stat.S_IMODE(os.stat(path).st_mode)
    except FileNotFoundError:
        existing_mode = 0o600
    fd, tmp = tempfile.mkstemp(prefix=".credentials.", suffix=".tmp", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w") as fh:
            fh.write(contents)
        os.chmod(tmp, existing_mode)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


if __name__ == "__main__":
    sys.exit(main())
